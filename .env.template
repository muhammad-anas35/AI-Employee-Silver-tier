# Vault Configuration
VAULT_PATH="AI_Employee_Vault"
DROP_FOLDER="~/AI_Employee_Drop"

# Gmail API Configuration (Silver Tier)
GMAIL_CLIENT_ID="your_gmail_client_id_here"
GMAIL_CLIENT_SECRET="your_gmail_client_secret_here"
GMAIL_CREDENTIALS_PATH="./credentials.json"
GMAIL_TOKEN_PATH="./token.json"

# WhatsApp Configuration (Silver Tier - Optional)
WHATSAPP_SESSION_PATH="./whatsapp_session"
WHATSAPP_HEADLESS=true

# LinkedIn Configuration (Silver Tier - Optional)
LINKEDIN_SESSION_PATH="./linkedin_session"
LINKEDIN_CLIENT_ID="your_linkedin_client_id_here"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret_here"

# Watcher Configuration
CHECK_INTERVAL=120  # seconds
ENABLE_GMAIL_WATCHER=true
ENABLE_WHATSAPP_WATCHER=false
ENABLE_FILESYSTEM_WATCHER=true

# Orchestrator Configuration
ORCHESTRATOR_CHECK_INTERVAL=60
CLAUDE_PROCESS_INTERVAL=300
DASHBOARD_UPDATE_INTERVAL=1800

# Logging
LOG_LEVEL="INFO"
LOG_PATH="AI_Employee_Vault/Logs"

# Claude Code Configuration
CLAUDE_CODE_PATH="claude"
AUTO_UPDATE_DASHBOARD=true

# Approval Thresholds
AUTO_APPROVE_THRESHOLD=50  # dollars
REQUIRE_APPROVAL_NEW_CONTACT=true
REQUIRE_APPROVAL_PAYMENT=true
REQUIRE_APPROVAL_SOCIAL_MEDIA=true

# Financial Tracking
CURRENCY="USD"
TRACK_EXPENSES=true
TRACK_REVENUE=true

# Security
ENABLE_AUDIT_LOGGING=true
ENABLE_ENCRYPTION=false
CREDENTIAL_ROTATION_DAYS=30
DRY_RUN=false
MAX_EMAILS_PER_HOUR=10
MAX_POSTS_PER_DAY=5

# Feature Flags (Silver Tier)
ENABLE_FILE_WATCHER=true
ENABLE_GMAIL_WATCHER=true
ENABLE_WHATSAPP_WATCHER=false
ENABLE_LINKEDIN_POSTER=true
ENABLE_EMAIL_SENDER=true
